# ── Smart Switch Backend – Environment Variables ─────────────────────────────

# Set to 1 on Windows/macOS dev machines (no real GPIO hardware).
# Set to 0 on Raspberry Pi to use real GPIO pins.
USE_MOCK_GPIO=1

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Timezone for NTP-corrected time and scheduler.
# Must be a valid pytz timezone string.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Kolkata

# Firebase Admin credentials for camera attendance writes.
# Use an absolute path or a path relative to backend/.
# Example (Windows): FIREBASE_SERVICE_ACCOUNT=C:/keys/smart-class-service-account.json
# Example (relative): FIREBASE_SERVICE_ACCOUNT=smart-class-da901-firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT=smart-class-da901-firebase-adminsdk-fbsvc-3b7bc6538d.json

# Flask host and port (used if you override app.run via env in future)
# FLASK_HOST=0.0.0.0
# FLASK_PORT=8000

# Camera tuning for Raspberry Pi (preview + face detection)
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=30
CAM_PREVIEW_FPS=15
CAM_DETECT_INTERVAL_S=0.30
CAM_SCALE=0.5
CAM_JPEG_QUALITY=55
CAM_CONTRAST=1.06
CAM_SATURATION=1.08
CAM_SHARPNESS=1.08
CAM_BRIGHTNESS=0.00
